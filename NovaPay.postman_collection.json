{
  "info": {
    "name": "NovaPay API",
    "description": "Complete Postman collection for NovaPay — a microservice payment backend with idempotent disbursement, atomic double-entry ledger, locked FX quotes, and pre-computed transaction history.\n\n**Setup:**\n1. Set the `baseUrl` variable to `http://localhost` (default after `docker compose up`)\n2. Set `adminKey` to match your `ADMIN_API_KEY` env var\n3. All monetary amounts must be strings (e.g. `\"100.00\"`), never JS floats\n\n**Key rules:**\n- `POST /transfers` and `POST /transfers/international` require a unique `Idempotency-Key` UUID per request\n- FX quotes expire after 60 seconds and are single-use\n- Admin endpoints require the `X-Admin-Key` header",
    "_postman_id": "novapay-collection-v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost",
      "type": "string",
      "description": "API Gateway base URL (Nginx). Default after docker compose up."
    },
    {
      "key": "accountServiceUrl",
      "value": "http://localhost:3001",
      "type": "string",
      "description": "Direct account-service URL (bypasses nginx). Health check only."
    },
    {
      "key": "transactionServiceUrl",
      "value": "http://localhost:3002",
      "type": "string",
      "description": "Direct transaction-service URL (bypasses nginx). Health check only."
    },
    {
      "key": "ledgerServiceUrl",
      "value": "http://localhost:3003",
      "type": "string",
      "description": "Direct ledger-service URL (bypasses nginx). Health check only."
    },
    {
      "key": "fxServiceUrl",
      "value": "http://localhost:3004",
      "type": "string",
      "description": "Direct fx-service URL (bypasses nginx). Health check only."
    },
    {
      "key": "payrollServiceUrl",
      "value": "http://localhost:3005",
      "type": "string",
      "description": "Direct payroll-service URL (bypasses nginx). Health check only."
    },
    {
      "key": "adminKey",
      "value": "secret-admin-key",
      "type": "string",
      "description": "Admin API key — must match ADMIN_API_KEY env var in admin-service"
    },
    {
      "key": "userId",
      "value": "user-001",
      "type": "string",
      "description": "Sample user/account ID for account-service requests"
    },
    {
      "key": "recipientId",
      "value": "user-002",
      "type": "string",
      "description": "Sample recipient ID for transfer requests"
    },
    {
      "key": "transactionId",
      "value": "",
      "type": "string",
      "description": "Populated by test scripts from transfer responses"
    },
    {
      "key": "fxQuoteId",
      "value": "",
      "type": "string",
      "description": "Populated by test scripts from FX quote responses"
    },
    {
      "key": "jobId",
      "value": "",
      "type": "string",
      "description": "Populated by test scripts from payroll job responses"
    }
  ],
  "item": [
    {
      "name": "Account Service",
      "description": "Wallet CRUD, debit/credit operations with optimistic locking and AES-256-GCM field encryption.",
      "item": [
        {
          "name": "Create Wallet",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-request-id",
                "value": "{{$guid}}",
                "description": "Optional — auto-generated if omitted"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/accounts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"currency\": \"USD\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Create a new wallet for a user. Returns 409 if a wallet already exists for the userId."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    if (body.userId) pm.collectionVariables.set('userId', body.userId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Wallet",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-request-id",
                "value": "{{$guid}}",
                "description": "Optional"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/accounts/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts", "{{userId}}"]
            },
            "description": "Retrieve a wallet by userId. Returns 404 if not found."
          },
          "response": []
        },
        {
          "name": "Debit Wallet",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-request-id",
                "value": "{{$guid}}",
                "description": "Optional"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/accounts/{{userId}}/debit",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts", "{{userId}}", "debit"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": \"50.00\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Debit an amount from the wallet. Amount must be a decimal string. Returns 402 on insufficient funds, 409 on concurrent modification."
          },
          "response": []
        },
        {
          "name": "Credit Wallet",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-request-id",
                "value": "{{$guid}}",
                "description": "Optional"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/accounts/{{userId}}/credit",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts", "{{userId}}", "credit"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": \"100.00\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Credit an amount to the wallet. Amount must be a decimal string. Returns 409 on concurrent modification."
          },
          "response": []
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{accountServiceUrl}}/api/health",
              "host": ["{{accountServiceUrl}}"],
              "path": ["api", "health"]
            },
            "description": "Direct health check (bypasses nginx — nginx has no route to /health). Returns { status: 'ok', service: 'account-service' }. Use GET {{baseUrl}}/api/admin/health for an aggregate check via gateway."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Transaction Service",
      "description": "Transfer saga engine with idempotency middleware, saga recovery worker, and stuck transaction detection.",
      "item": [
        {
          "name": "Domestic Transfer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{$guid}}",
                "description": "REQUIRED — unique UUID per logical operation. Reusing with same payload returns cached result; reusing with different payload returns 409."
              },
              {
                "key": "x-request-id",
                "value": "{{$guid}}",
                "description": "Optional"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/transfers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transfers"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senderId\": \"{{userId}}\",\n  \"recipientId\": \"{{recipientId}}\",\n  \"amount\": \"25.00\",\n  \"currency\": \"USD\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Initiate a domestic transfer between two wallets. A flat $2.00 fee is applied — sender is debited (amount + $2.00). The saga: debit sender (amount + fee) → record DEBIT_COMPLETE → credit recipient (amount) → write balanced ledger entries (transfer pair + fee pair) → record COMPLETED. Response includes a `fee` field. Recovery worker handles partial failures."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    if (body.transactionId) pm.collectionVariables.set('transactionId', body.transactionId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "International Transfer (FX)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{$guid}}",
                "description": "REQUIRED — unique UUID per logical operation."
              },
              {
                "key": "x-request-id",
                "value": "{{$guid}}",
                "description": "Optional"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/transfers/international",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transfers", "international"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senderId\": \"{{userId}}\",\n  \"recipientId\": \"{{recipientId}}\",\n  \"amount\": \"100.00\",\n  \"currency\": \"USD\",\n  \"fxQuoteId\": \"{{fxQuoteId}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Initiate a cross-currency transfer. Requires a valid (non-expired, unconsumed) fxQuoteId from the FX service. A flat $2.00 fee is applied — sender is debited (amount + $2.00). The locked rate is written to every ledger entry. Response includes a `fee` field."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    if (body.transactionId) pm.collectionVariables.set('transactionId', body.transactionId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Transaction",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-request-id",
                "value": "{{$guid}}",
                "description": "Optional"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/transfers/{{transactionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transfers", "{{transactionId}}"]
            },
            "description": "Retrieve a transaction by ID. Status flow: PENDING → PROCESSING → COMPLETED | FAILED | REVERSED."
          },
          "response": []
        },
        {
          "name": "Get Stuck Transactions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-request-id",
                "value": "{{$guid}}",
                "description": "Optional"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/transfers/stuck",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transfers", "stuck"]
            },
            "description": "Returns transactions in PROCESSING status for more than 2 minutes. Used for saga recovery monitoring."
          },
          "response": []
        },
        {
          "name": "Reverse Transaction",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-request-id",
                "value": "{{$guid}}",
                "description": "Optional"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/transfers/{{transactionId}}/reverse",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transfers", "{{transactionId}}", "reverse"]
            },
            "body": {
              "mode": "raw",
              "raw": "",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Manually reverse a transaction. Only valid for transactions in PROCESSING status. Returns 409 if transaction is not reversible."
          },
          "response": []
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{transactionServiceUrl}}/api/health",
              "host": ["{{transactionServiceUrl}}"],
              "path": ["api", "health"]
            },
            "description": "Direct health check (bypasses nginx). Returns { status: 'ok', service: 'transaction-service' }."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Ledger Service",
      "description": "Double-entry bookkeeping with SHA-256 audit hash chain and invariant checks. All entries must balance: sum(DEBIT) === sum(CREDIT).",
      "item": [
        {
          "name": "Create Ledger Entries",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.variables.set('transactionId', 'txn-' + pm.variables.replaceIn('{{$guid}}'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-request-id",
                "value": "{{$guid}}",
                "description": "Optional"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/ledger/entries",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ledger", "entries"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entries\": [\n    {\n      \"transactionId\": \"{{transactionId}}\",\n      \"accountId\": \"{{userId}}\",\n      \"amount\": \"100.00\",\n      \"entryType\": \"DEBIT\",\n      \"currency\": \"USD\"\n    },\n    {\n      \"transactionId\": \"{{transactionId}}\",\n      \"accountId\": \"{{recipientId}}\",\n      \"amount\": \"100.00\",\n      \"entryType\": \"CREDIT\",\n      \"currency\": \"USD\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Record double-entry bookkeeping entries. DEBIT totals must equal CREDIT totals (validated with decimal.js). Returns 422 on imbalance — no partial writes."
          },
          "response": []
        },
        {
          "name": "Get Account Balance",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-request-id",
                "value": "{{$guid}}",
                "description": "Optional"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/ledger/balance/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ledger", "balance", "{{userId}}"]
            },
            "description": "Get the computed ledger balance for an account. Derived from the sum of all debit/credit entries."
          },
          "response": []
        },
        {
          "name": "Verify Transaction Hash Chain",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-request-id",
                "value": "{{$guid}}",
                "description": "Optional"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/ledger/verify/{{transactionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ledger", "verify", "{{transactionId}}"]
            },
            "description": "Recompute and verify the SHA-256 audit hash chain for a transaction. Any DB-level tamper breaks the chain. Genesis entry uses sentinel NOVAPAY_GENESIS_0000."
          },
          "response": []
        },
        {
          "name": "Invariant Check",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-request-id",
                "value": "{{$guid}}",
                "description": "Optional"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/ledger/invariant-check",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ledger", "invariant-check"]
            },
            "description": "Check global ledger invariant: total DEBITs must equal total CREDITs. Prometheus counter ledger_invariant_violation_total fires an alert at > 0."
          },
          "response": []
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{ledgerServiceUrl}}/api/health",
              "host": ["{{ledgerServiceUrl}}"],
              "path": ["api", "health"]
            },
            "description": "Direct health check (bypasses nginx). Returns { status: 'ok', service: 'ledger-service' }."
          },
          "response": []
        }
      ]
    },
    {
      "name": "FX Service",
      "description": "FX quote lifecycle — 60-second TTL, single-use atomic consumption, locked rate on ledger. No fallback to stale/cached rates.",
      "item": [
        {
          "name": "Create FX Quote",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-request-id",
                "value": "{{$guid}}",
                "description": "Optional"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/fx/quote",
              "host": ["{{baseUrl}}"],
              "path": ["api", "fx", "quote"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fromCurrency\": \"USD\",\n  \"toCurrency\": \"EUR\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Request an FX rate quote. Quote is valid for 60 seconds and can only be used once. Returns 503 if FX provider is unavailable — no cached fallback."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    if (body.quoteId) pm.collectionVariables.set('fxQuoteId', body.quoteId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get FX Quote",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-request-id",
                "value": "{{$guid}}",
                "description": "Optional"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/fx/quote/{{fxQuoteId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "fx", "quote", "{{fxQuoteId}}"]
            },
            "description": "Retrieve an FX quote by ID. Returns computed fields: isExpired, isUsed, secondsRemaining. Returns 400 on invalid UUID, 404 if not found."
          },
          "response": []
        },
        {
          "name": "Consume FX Quote",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-request-id",
                "value": "{{$guid}}",
                "description": "Optional"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/fx/quote/{{fxQuoteId}}/consume",
              "host": ["{{baseUrl}}"],
              "path": ["api", "fx", "quote", "{{fxQuoteId}}", "consume"]
            },
            "body": {
              "mode": "raw",
              "raw": "",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Atomically consume an FX quote (UPDATE … WHERE usedAt IS NULL RETURNING). Returns 422 QUOTE_ALREADY_USED or 422 QUOTE_EXPIRED. Race-condition safe."
          },
          "response": []
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{fxServiceUrl}}/api/health",
              "host": ["{{fxServiceUrl}}"],
              "path": ["api", "health"]
            },
            "description": "Direct health check (bypasses nginx). Returns { status: 'ok', service: 'fx-service' }."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Payroll Service",
      "description": "Bulk disbursements with Redis per-employer queue, checkpoint resumability, and deterministic idempotency keys.",
      "item": [
        {
          "name": "Create Payroll Job",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-request-id",
                "value": "{{$guid}}",
                "description": "Optional"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/payroll/jobs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payroll", "jobs"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employerId\": \"employer-001\",\n  \"disbursements\": [\n    {\n      \"employeeId\": \"employee-001\",\n      \"amount\": \"3500.00\",\n      \"currency\": \"USD\"\n    },\n    {\n      \"employeeId\": \"employee-002\",\n      \"amount\": \"4200.00\",\n      \"currency\": \"USD\"\n    },\n    {\n      \"employeeId\": \"employee-003\",\n      \"amount\": \"2800.00\",\n      \"currency\": \"USD\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Create and enqueue a bulk payroll disbursement job. Returns 202 Accepted — processing is async. Crash recovery resumes from checkpointIndex. Idempotency keys are deterministic: {jobId}-{employeeId}-{index}."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 202) {",
                  "    const body = pm.response.json();",
                  "    if (body.jobId) pm.collectionVariables.set('jobId', body.jobId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Payroll Job",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-request-id",
                "value": "{{$guid}}",
                "description": "Optional"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/payroll/jobs/{{jobId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payroll", "jobs", "{{jobId}}"]
            },
            "description": "Get payroll job status including processedCount, failedCount, and checkpointIndex for crash recovery visibility."
          },
          "response": []
        },
        {
          "name": "List Payroll Jobs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-request-id",
                "value": "{{$guid}}",
                "description": "Optional"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/payroll/jobs?limit=20&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payroll", "jobs"],
              "query": [
                {
                  "key": "limit",
                  "value": "20",
                  "description": "Max results (default 50, max 200)"
                },
                {
                  "key": "offset",
                  "value": "0",
                  "description": "Pagination offset (default 0)"
                }
              ]
            },
            "description": "List all payroll jobs with pagination."
          },
          "response": []
        },
        {
          "name": "Get Job Disbursements",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-request-id",
                "value": "{{$guid}}",
                "description": "Optional"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/payroll/jobs/{{jobId}}/disbursements?limit=50&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payroll", "jobs", "{{jobId}}", "disbursements"],
              "query": [
                {
                  "key": "limit",
                  "value": "50",
