    {
      "name": "Flows",
      "description": "End-to-end request sequences demonstrating the key NovaPay scenarios. Run these folders in order to exercise full flows.",
      "item": [
        {
          "name": "Domestic Transfer Flow",
          "description": "1. Create sender wallet → 2. Create recipient wallet → 3. Credit sender → 4. Initiate transfer → 5. Get transaction status",
          "item": [
            {
              "name": "1. Create Sender Wallet",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/accounts",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "accounts"]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"userId\": \"sender-{{$randomInt}}\",\n  \"currency\": \"USD\"\n}",
                  "options": { "raw": { "language": "json" } }
                }
              },
              "response": [],
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 201) {",
                      "    pm.collectionVariables.set('userId', pm.response.json().userId);",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            },
            {
              "name": "2. Create Recipient Wallet",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/accounts",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "accounts"]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"userId\": \"recipient-{{$randomInt}}\",\n  \"currency\": \"USD\"\n}",
                  "options": { "raw": { "language": "json" } }
                }
              },
              "response": [],
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 201) {",
                      "    pm.collectionVariables.set('recipientId', pm.response.json().userId);",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            },
            {
              "name": "3. Fund Sender Wallet",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/accounts/{{userId}}/credit",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "accounts", "{{userId}}", "credit"]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"amount\": \"500.00\"\n}",
                  "options": { "raw": { "language": "json" } }
                }
              },
              "response": []
            },
            {
              "name": "4. Initiate Transfer",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Idempotency-Key", "value": "{{$guid}}" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/transfers",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "transfers"]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"senderId\": \"{{userId}}\",\n  \"recipientId\": \"{{recipientId}}\",\n  \"amount\": \"100.00\",\n  \"currency\": \"USD\"\n}",
                  "options": { "raw": { "language": "json" } }
                }
              },
              "response": [],
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 201) {",
                      "    pm.collectionVariables.set('transactionId', pm.response.json().transactionId);",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            },
            {
              "name": "5. Check Transaction Status",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/transfers/{{transactionId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "transfers", "{{transactionId}}"]
                }
              },
              "response": []
            }
          ]
        },
        {
          "name": "FX Transfer Flow",
          "description": "1. Create FX quote → 2. Check quote → 3. Initiate international transfer (quote consumed atomically)",
          "item": [
            {
              "name": "1. Get FX Quote",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/fx/quote",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "fx", "quote"]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"fromCurrency\": \"USD\",\n  \"toCurrency\": \"EUR\"\n}",
                  "options": { "raw": { "language": "json" } }
                }
              },
              "response": [],
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 201) {",
                      "    pm.collectionVariables.set('fxQuoteId', pm.response.json().quoteId);",
                      "    console.log('Quote expires in 60s. Proceed quickly!');",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            },
            {
              "name": "2. Verify Quote (optional)",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/fx/quote/{{fxQuoteId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "fx", "quote", "{{fxQuoteId}}"]
                }
              },
              "response": []
            },
            {
              "name": "3. International Transfer",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Idempotency-Key", "value": "{{$guid}}" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/transfers/international",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "transfers", "international"]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"senderId\": \"{{userId}}\",\n  \"recipientId\": \"{{recipientId}}\",\n  \"amount\": \"200.00\",\n  \"currency\": \"USD\",\n  \"fxQuoteId\": \"{{fxQuoteId}}\"\n}",
                  "options": { "raw": { "language": "json" } }
                }
              },
              "response": [],
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 201) {",
                      "    pm.collectionVariables.set('transactionId', pm.response.json().transactionId);",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            }
          ]
        },
        {
          "name": "Idempotency Demo",
          "description": "Demonstrates idempotency behavior: send the same request twice with the same Idempotency-Key. The second call must return the cached result, not create a new transaction.",
          "item": [
            {
              "name": "Transfer (first attempt)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Idempotency-Key", "value": "demo-idem-key-fixed-001" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/transfers",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "transfers"]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"senderId\": \"{{userId}}\",\n  \"recipientId\": \"{{recipientId}}\",\n  \"amount\": \"10.00\",\n  \"currency\": \"USD\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "description": "First attempt — creates the transaction. Note the fixed Idempotency-Key."
              },
              "response": []
            },
            {
              "name": "Transfer (duplicate — should return cached)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Idempotency-Key", "value": "demo-idem-key-fixed-001" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/transfers",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "transfers"]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"senderId\": \"{{userId}}\",\n  \"recipientId\": \"{{recipientId}}\",\n  \"amount\": \"10.00\",\n  \"currency\": \"USD\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "description": "Exact duplicate — same key, same payload. Should return the same transactionId from cache. No new transaction created."
              },
              "response": []
            },
            {
              "name": "Transfer (conflict — should return 409)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Idempotency-Key", "value": "demo-idem-key-fixed-001" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/transfers",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "transfers"]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"senderId\": \"{{userId}}\",\n  \"recipientId\": \"{{recipientId}}\",\n  \"amount\": \"99.00\",\n  \"currency\": \"USD\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "description": "Same key, DIFFERENT payload (amount changed to 99.00). Should return 409 IDEMPOTENCY_CONFLICT."
              },
              "response": []
            }
          ]
        }
      ]
    }
  ]
}
