{
  "info": {
    "_postman_id": "novapay-collection-v1",
    "name": "NovaPay API",
    "description": "Complete API collection for NovaPay backend services. All requests route through the Nginx gateway at {{baseUrl}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost",
      "type": "string"
    },
    {
      "key": "adminKey",
      "value": "admin-secret",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Account Service",
      "item": [
        {
          "name": "Create Account",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/accounts", "host": ["{{baseUrl}}"], "path": ["api", "accounts"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"user-123\",\n  \"currency\": \"USD\"\n}"
            },
            "description": "Create a new wallet for a user. Returns walletId and initial balance of 0."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"walletId\": \"a1b2c3d4-e5f6-7890-abcd-ef1234567890\",\n    \"userId\": \"user-123\",\n    \"balance\": \"0\",\n    \"currency\": \"USD\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Get Balance",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/accounts/a1b2c3d4-e5f6-7890-abcd-ef1234567890/balance",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts", "a1b2c3d4-e5f6-7890-abcd-ef1234567890", "balance"]
            },
            "description": "Get current balance for a wallet."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"accountId\": \"a1b2c3d4-e5f6-7890-abcd-ef1234567890\",\n  \"balance\": \"950.00000000\",\n  \"currency\": \"USD\"\n}"
            }
          ]
        },
        {
          "name": "Debit Account (internal)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/accounts/a1b2c3d4-e5f6-7890-abcd-ef1234567890/debit",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts", "a1b2c3d4-e5f6-7890-abcd-ef1234567890", "debit"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionId\": \"txn-uuid\",\n  \"amount\": \"100\",\n  \"currency\": \"USD\"\n}"
            },
            "description": "Called internally by transaction-service. Reduces account balance."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{ \"ok\": true, \"newBalance\": \"900.00000000\" }"
            },
            {
              "name": "422 Insufficient Funds",
              "status": "Unprocessable Entity",
              "code": 422,
              "body": "{ \"error\": \"INSUFFICIENT_FUNDS\" }"
            }
          ]
        },
        {
          "name": "Credit Account (internal)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/accounts/b2c3d4e5-f6a7-8901-bcde-f12345678901/credit",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts", "b2c3d4e5-f6a7-8901-bcde-f12345678901", "credit"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionId\": \"txn-uuid\",\n  \"amount\": \"100\",\n  \"currency\": \"USD\",\n  \"isReversal\": false\n}"
            },
            "description": "Called internally by transaction-service. Increases account balance. Pass isReversal=true for compensating transactions."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{ \"ok\": true, \"newBalance\": \"1100.00000000\" }"
            }
          ]
        }
      ]
    },
    {
      "name": "FX Service",
      "item": [
        {
          "name": "Request FX Quote",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/fx/quote", "host": ["{{baseUrl}}"], "path": ["api", "fx", "quote"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fromCurrency\": \"USD\",\n  \"toCurrency\": \"BDT\",\n  \"amount\": \"2000\"\n}"
            },
            "description": "Get a locked FX rate quote. Valid for 60 seconds. Single-use — once consumed by a transfer it cannot be reused."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"quoteId\": \"fx-quote-uuid\",\n  \"rate\": \"110.5\",\n  \"expiresAt\": \"2024-01-01T00:01:00.000Z\",\n  \"secondsRemaining\": 60\n}"
            },
            {
              "name": "503 Provider Down",
              "status": "Service Unavailable",
              "code": 503,
              "body": "{ \"error\": \"FX provider unavailable\" }"
            }
          ]
        },
        {
          "name": "Get Quote Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/fx/quote/fx-quote-uuid",
              "host": ["{{baseUrl}}"],
              "path": ["api", "fx", "quote", "fx-quote-uuid"]
            },
            "description": "Fetch quote details including expiry state and remaining seconds."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": \"fx-quote-uuid\",\n  \"fromCurrency\": \"USD\",\n  \"toCurrency\": \"BDT\",\n  \"rate\": \"110.5\",\n  \"expiresAt\": \"2024-01-01T00:01:00.000Z\",\n  \"usedAt\": null,\n  \"isExpired\": false,\n  \"isUsed\": false,\n  \"secondsRemaining\": 42\n}"
            }
          ]
        },
        {
          "name": "Consume Quote (internal)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/fx/quote/fx-quote-uuid/consume",
              "host": ["{{baseUrl}}"],
              "path": ["api", "fx", "quote", "fx-quote-uuid", "consume"]
            },
            "description": "Atomically marks the quote as used. Called by transaction-service during FX transfers. Returns 422 if expired or already used."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{ \"quoteId\": \"fx-quote-uuid\", \"rate\": \"110.5\", \"usedAt\": \"2024-01-01T00:00:30.000Z\" }"
            },
            {
              "name": "422 Expired",
              "status": "Unprocessable Entity",
              "code": 422,
              "body": "{ \"error\": \"QUOTE_EXPIRED\" }"
            },
            {
              "name": "422 Already Used",
              "status": "Unprocessable Entity",
              "code": 422,
              "body": "{ \"error\": \"QUOTE_ALREADY_USED\" }"
            }
          ]
        }
      ]
    },
    {
      "name": "Transaction Service",
      "item": [
        {
          "name": "Domestic Transfer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{$randomUUID}}", "description": "Client-generated UUID. Reuse on retry, generate fresh for new transfers." }
            ],
            "url": { "raw": "{{baseUrl}}/api/transfers", "host": ["{{baseUrl}}"], "path": ["api", "transfers"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senderId\": \"user-1\",\n  \"recipientId\": \"user-2\",\n  \"amount\": \"100\",\n  \"currency\": \"USD\"\n}"
            },
            "description": "Transfer between two USD wallets. Executes debit → credit → ledger entry atomically via Saga. Idempotent."
          },
          "response": [
            {
              "name": "200 Completed",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"transactionId\": \"txn-uuid\",\n  \"status\": \"COMPLETED\",\n  \"amount\": \"100\",\n  \"currency\": \"USD\"\n}"
            },
            {
              "name": "200 Duplicate (idempotent replay)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"transactionId\": \"txn-uuid\",\n  \"status\": \"COMPLETED\",\n  \"amount\": \"100\",\n  \"currency\": \"USD\"\n}"
            },
            {
              "name": "409 Idempotency Conflict",
              "status": "Conflict",
              "code": 409,
              "body": "{\n  \"error\": \"IDEMPOTENCY_CONFLICT\",\n  \"message\": \"Idempotency key already used with a different payload (original amount: 100 USD, new amount: 200 USD)\"\n}"
            }
          ]
        },
        {
          "name": "International Transfer (FX)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{$randomUUID}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/transfers/international",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transfers", "international"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senderId\": \"user-1\",\n  \"recipientId\": \"user-2\",\n  \"amount\": \"2000\",\n  \"currency\": \"USD\",\n  \"fxQuoteId\": \"fx-quote-uuid\"\n}"
            },
            "description": "Transfer with FX conversion. Consumes the locked quote atomically. The quote must be valid (not expired, not used). Locked rate is written to the ledger entry."
          },
          "response": [
            {
              "name": "200 Completed",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"transactionId\": \"txn-uuid\",\n  \"status\": \"COMPLETED\",\n  \"amount\": \"2000\",\n  \"currency\": \"USD\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Payroll Service",
      "item": [
        {
          "name": "Create Payroll Job",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/payroll/jobs", "host": ["{{baseUrl}}"], "path": ["api", "payroll", "jobs"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employerId\": \"corp-1\",\n  \"disbursements\": [\n    { \"employeeId\": \"emp-1\", \"amount\": \"5000\", \"currency\": \"USD\" },\n    { \"employeeId\": \"emp-2\", \"amount\": \"4500\", \"currency\": \"USD\" },\n    { \"employeeId\": \"emp-3\", \"amount\": \"3800\", \"currency\": \"USD\" }\n  ]\n}"
            },
            "description": "Enqueue a payroll disbursement job. The job is processed asynchronously by a Redis-backed worker with concurrency=1 per employer. Supports crash recovery via checkpointIndex."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"jobId\": \"job-uuid\",\n  \"status\": \"QUEUED\",\n  \"totalCount\": 3,\n  \"totalAmount\": \"13300.00000000\"\n}"
            }
          ]
        },
        {
          "name": "Get Job Progress",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/payroll/jobs/job-uuid",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payroll", "jobs", "job-uuid"]
            },
            "description": "Poll job status. checkpointIndex advances after each successful disbursement."
          },
          "response": [
            {
              "name": "200 In Progress",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": \"job-uuid\",\n  \"status\": \"PROCESSING\",\n  \"totalCount\": 3,\n  \"processedCount\": 1,\n  \"failedCount\": 0,\n  \"checkpointIndex\": 1\n}"
            },
            {
              "name": "200 Completed",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": \"job-uuid\",\n  \"status\": \"COMPLETED\",\n  \"totalCount\": 3,\n  \"processedCount\": 3,\n  \"failedCount\": 0,\n  \"checkpointIndex\": 3\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Admin Service",
      "item": [
        {
          "name": "Ledger Invariant Check",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Admin-Key", "value": "{{adminKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/ledger/invariant",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "ledger", "invariant"]
            },
            "description": "Global sum check across all ledger entries. diff should always be 0. A non-zero diff means a debit was written without a matching credit (or vice versa)."
          },
          "response": [
            {
              "name": "200 Balanced",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"debitTotal\": \"1000.00\",\n  \"creditTotal\": \"1000.00\",\n  \"diff\": \"0\",\n  \"balanced\": true\n}"
            }
          ]
        },
        {
          "name": "Verify Hash Chain",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Admin-Key", "value": "{{adminKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/ledger/verify/txn-uuid",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "ledger", "verify", "txn-uuid"]
            },
            "description": "Recompute the SHA-256 hash chain for all entries belonging to a transaction. Returns tamperedAt if any entry was modified in the database after the fact."
          },
          "response": [
            {
              "name": "200 Valid",
              "status": "OK",
              "code": 200,
              "body": "{ \"valid\": true }"
            },
            {
              "name": "200 Tampered",
              "status": "OK",
              "code": 200,
              "body": "{ \"valid\": false, \"tamperedAt\": \"entry-uuid\" }"
            }
          ]
        },
        {
          "name": "Account Balance (Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Admin-Key", "value": "{{adminKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/accounts/user-1/balance",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "accounts", "user-1", "balance"]
            },
            "description": "Proxy to account-service balance endpoint. Requires admin key."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{ \"accountId\": \"user-1\", \"balance\": \"900.00000000\", \"currency\": \"USD\" }"
            }
          ]
        }
      ]
    },
    {
      "name": "Happy Path",
      "description": "End-to-end flow: Create Account → Get FX Quote → International Transfer → Check Ledger Balance → Check Transaction Status",
      "item": [
        {
          "name": "Step 1 — Create Sender Account",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/accounts", "host": ["{{baseUrl}}"], "path": ["api", "accounts"] },
            "body": {
              "mode": "raw",
              "raw": "{ \"userId\": \"happy-sender\", \"currency\": \"USD\" }"
            },
            "description": "Create the sender's wallet. Copy walletId into collection variable 'senderWalletId'."
          },
          "response": []
        },
        {
          "name": "Step 2 — Create Recipient Account",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/accounts", "host": ["{{baseUrl}}"], "path": ["api", "accounts"] },
            "body": {
              "mode": "raw",
              "raw": "{ \"userId\": \"happy-recipient\", \"currency\": \"BDT\" }"
            },
            "description": "Create the recipient's wallet. Copy walletId into 'recipientWalletId'."
          },
          "response": []
        },
        {
          "name": "Step 3 — Get FX Quote (USD → BDT)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/fx/quote", "host": ["{{baseUrl}}"], "path": ["api", "fx", "quote"] },
            "body": {
              "mode": "raw",
              "raw": "{ \"fromCurrency\": \"USD\", \"toCurrency\": \"BDT\", \"amount\": \"100\" }"
            },
            "description": "Request a locked FX rate. Quote is valid for 60 seconds. Copy quoteId into 'fxQuoteId'."
          },
          "response": []
        },
        {
          "name": "Step 4 — International Transfer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "happy-path-transfer-001" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/transfers/international",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transfers", "international"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senderId\": \"happy-sender\",\n  \"recipientId\": \"happy-recipient\",\n  \"amount\": \"100\",\n  \"currency\": \"USD\",\n  \"fxQuoteId\": \"{{fxQuoteId}}\"\n}"
            },
            "description": "Execute the transfer using the locked FX quote. Copy transactionId into 'transactionId'."
          },
          "response": []
        },
        {
          "name": "Step 5 — Check Sender Ledger Balance",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Admin-Key", "value": "{{adminKey}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/admin/accounts/happy-sender/balance",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "accounts", "happy-sender", "balance"]
            },
            "description": "Verify sender balance decreased by $100."
          },
          "response": []
        },
        {
          "name": "Step 6 — Verify Hash Chain",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Admin-Key", "value": "{{adminKey}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/admin/ledger/verify/{{transactionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "ledger", "verify", "{{transactionId}}"]
            },
            "description": "Verify the audit hash chain for the completed transaction. Should return { valid: true }."
          },
          "response": []
        }
      ]
    }
  ]
}
