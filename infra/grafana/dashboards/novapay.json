{
  "title": "NovaPay Overview",
  "uid": "novapay-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Transaction Throughput",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(transactions_total[1m]))",
          "legendFormat": "tx/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 2,
      "title": "Failed Transaction Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "100 * sum(rate(transactions_total{status=\"failed\"}[5m])) / sum(rate(transactions_total[5m]))",
          "legendFormat": "failure %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Ledger Invariant Violations",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "sum(ledger_invariant_violation_total)",
          "legendFormat": "violations"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OK", "color": "green" } } }
          ]
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "id": 4,
      "title": "p95 Latency per Service",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 8, "w": 18, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (job, le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{job}} p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 5,
      "title": "p99 Latency per Service",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 18, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (job, le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{job}} p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 6,
      "title": "Active Payroll Jobs",
      "type": "stat",
      "gridPos": { "x": 18, "y": 16, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "sum(active_payroll_jobs)",
          "legendFormat": "active jobs"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "orange", "value": 20 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area" }
    }
  ]
}
